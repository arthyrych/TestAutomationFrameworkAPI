{
  "name": "test-automation-framework-api",
  "version": "1.0.0",
  "description": "REST, GraphQL and WebSocket API test automation framework",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "mocha \"specs/**/*.spec.ts\"",
    "test:graphql": "mocha \"specs/graphql/**/*.spec.ts\"",
    "test:healthcheck": "mocha \"specs/**/healthcheck.spec.ts\"",
    "test:rest": "mocha \"specs/rest/**/*.spec.ts\"",
    "test:users": "mocha \"specs/**/users.*.spec.ts\"",
    "test:ws": "mocha \"specs/ws/**/*.spec.ts\"",
    "lint": "eslint . && prettier --check . && tsc",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf junit-results",
    "prepare": "husky"
  },
  "author": "Artem Hyrych",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@faker-js/faker": "10.5.0",
    "@types/chai": "5.2.3",
    "@types/mocha": "10.0.10",
    "@types/node": "22.20.0",
    "@types/supertest": "7.2.0",
    "chai": "6.2.2",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "mocha": "11.7.6",
    "mocha-junit-reporter": "2.2.1",
    "mocha-multi-reporters": "1.5.1",
    "mocha-steps": "1.3.0",
    "prettier": "3.9.4",
    "supertest": "7.2.2",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "zod": "4.4.3"
  },
  "engines": {
    "node": ">=22.9.0"
  }
}
